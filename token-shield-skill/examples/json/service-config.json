{
    "_comment": "Payment API runtime configuration — loaded at startup from S3",
    "_last_updated": "2024-03-10T14:00:00Z",
    "_owner": "platform-team",
    "service": {
        "name": "payment-api",
        "version": "2.4.1",
        "environment": "production",
        "region": "eu-west-1",
        "description": "Handles all inbound payment processing requests for the platform"
    },
    "server": {
        "port": 8080,
        "host": "0.0.0.0",
        "read_timeout_seconds": 30,
        "write_timeout_seconds": 30,
        "idle_timeout_seconds": 120,
        "max_header_bytes": 1048576,
        "enable_http2": true,
        "graceful_shutdown_timeout_seconds": 30
    },
    "database": {
        "host": "db.payments.internal",
        "port": 5432,
        "name": "payments",
        "max_open_connections": 25,
        "max_idle_connections": 10,
        "connection_max_lifetime_seconds": 300,
        "connection_max_idle_time_seconds": 60,
        "ssl_mode": "require",
        "statement_timeout_ms": 5000,
        "lock_timeout_ms": 1000
    },
    "cache": {
        "provider": "redis",
        "host": "redis.payments.internal",
        "port": 6379,
        "max_retries": 3,
        "dial_timeout_seconds": 5,
        "read_timeout_seconds": 3,
        "write_timeout_seconds": 3,
        "pool_size": 10,
        "min_idle_connections": 5,
        "ttl_seconds": 300
    },
    "payment_providers": {
        "stripe": {
            "enabled": true,
            "base_url": "https://api.stripe.com",
            "timeout_ms": 3000,
            "max_retries": 2,
            "retry_delay_ms": 500,
            "circuit_breaker": {
                "enabled": true,
                "failure_threshold": 3,
                "success_threshold": 1,
                "timeout_seconds": 30,
                "half_open_max_calls": 1
            }
        },
        "adyen": {
            "enabled": false,
            "base_url": "https://checkout-live.adyen.com",
            "timeout_ms": 3000,
            "max_retries": 2,
            "retry_delay_ms": 500,
            "circuit_breaker": {
                "enabled": true,
                "failure_threshold": 3,
                "success_threshold": 1,
                "timeout_seconds": 30,
                "half_open_max_calls": 1
            }
        }
    },
    "observability": {
        "metrics": {
            "enabled": true,
            "provider": "cloudwatch",
            "namespace": "PaymentAPI",
            "flush_interval_seconds": 60
        },
        "tracing": {
            "enabled": true,
            "provider": "xray",
            "sampling_rate": 0.05
        },
        "logging": {
            "level": "info",
            "format": "json",
            "include_request_body": false,
            "include_response_body": false,
            "slow_request_threshold_ms": 1000
        }
    },
    "feature_flags": {
        "enable_3ds2": true,
        "enable_saved_cards": true,
        "enable_apple_pay": false,
        "enable_google_pay": false,
        "enable_klarna": false,
        "idempotency_key_ttl_hours": 24
    },
    "rate_limiting": {
        "enabled": true,
        "requests_per_second": 500,
        "burst": 1000,
        "by_ip": true,
        "by_api_key": true
    }
}